# Optional environment overrides for local development.
# The plugin is expected to support environment variables and plugin config together.

GOOGLE_CALENDAR_CREDENTIALS_PATH=./secrets/google-oauth-client.json
GOOGLE_CALENDAR_TOKEN_PATH=./secrets/google-calendar-token.json
GOOGLE_CALENDAR_OAUTH_REDIRECT_URI=http://127.0.0.1:3000/oauth2callback
GOOGLE_CALENDAR_DEFAULT_CALENDAR_ID=primary
GOOGLE_CALENDAR_DEFAULT_TIME_ZONE=America/Los_Angeles
GOOGLE_CALENDAR_CONFIRMATION_MODE=when-ambiguous
GOOGLE_CALENDAR_UPCOMING_WINDOW_DAYS=7
GOOGLE_CALENDAR_READ_ONLY_MODE=false
